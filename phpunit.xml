<?xml version="1.0" encoding="UTF-8"?>
<!--
  PHPUnit configuration for Dungeon Crawler tester module.

  Usage:
    cd sites/dungeoncrawler/web
    ../vendor/bin/phpunit -c modules/custom/dungeoncrawler_tester/phpunit.xml

  IMPORTANT: Tests must be run from the web/ directory (DRUPAL_ROOT) to ensure
  that relative paths used by Drupal's test framework resolve correctly. Running
  from any other directory will cause "Failed to open settings.php" errors.

  Suites:
    - unit: Isolated service/unit coverage
    - functional: Browser tests for controllers/routes/workflows

  Bootstrap:
    Uses custom tests/bootstrap.php to ensure the sites/simpletest directory
    exists and is writable before running tests. This is required for Drupal's
    BrowserTestBase which creates temporary test site directories.
    The module's bootstrap.php includes Drupal core's bootstrap.php.

  Test Failure Configuration:
    failOnDeprecation, failOnNotice, and failOnWarning are set to false to
    prevent PHPUnit deprecations and warnings from failing the test suite.
    These warnings should be addressed in future updates but should not block
    the test suite from passing. Risky, incomplete, and skipped test flags
    remain enabled to maintain test quality.
--> 
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.5/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         failOnDeprecation="false"
         failOnNotice="false"
         failOnWarning="false"
         failOnPhpunitDeprecation="false">
  
  <!-- Extensions -->
  <extensions>
    <bootstrap class="Drupal\Tests\dungeoncrawler_tester\Extension\TestEnvironmentSetup"/>
  </extensions>
  
  <!-- Test Suites -->
  <testsuites>
    <testsuite name="unit">
      <directory>tests/src/Unit</directory>
      <exclude>tests/src/Unit/Traits</exclude>
    </testsuite>

    <testsuite name="functional">
      <directory>tests/src/Functional</directory>
    </testsuite>
  </testsuites>

  <source>
    <include>
      <directory suffix=".php">src</directory>
    </include>
    <exclude>
      <directory>tests</directory>
    </exclude>
  </source>
  
  <!--
    Code Coverage disabled - requires pcov or xdebug extension
    
    To enable code coverage, install one of:
    - pecl install pcov (recommended, faster)
    - pecl install xdebug (full debugging features)
    
  <coverage>
    <report>
      <html outputDirectory="tests/coverage/html"/>
      <text outputFile="tests/coverage/coverage.txt"/>
    </report>
  </coverage>
  -->
  
  <!-- PHP Environment -->
  <php>
    <!--
      Drupal test database.
      Must be provided by your local/CI environment, for example:
      export SIMPLETEST_DB='mysql://user:pass@127.0.0.1:3306/database'
    -->
    
    <!-- Base URL for functional tests -->
    <env name="SIMPLETEST_BASE_URL" value="http://localhost:8080"/>
    
    <!-- Browser output directory -->
    <env name="BROWSERTEST_OUTPUT_DIRECTORY" value="../../../../sites/simpletest/browser_output"/>
    
    <!-- Symfony deprecation helper - disable to prevent deprecations from causing test failures -->
    <env name="SYMFONY_DEPRECATIONS_HELPER" value="disabled"/>
    
    <!-- Memory limit -->
    <ini name="memory_limit" value="512M"/>
    
    <!--
      IMPORTANT: Functional tests also require write access to web/sites/simpletest/
      This directory stores temporary test site configurations (settings.php).
      
      For local/CI testing environments, use 777 permissions:
        chmod 777 web/sites/simpletest
      
      For more restricted environments, use 775 and ensure your user is in the web server group:
        sudo usermod -a -G www-data $USER
        chmod 775 web/sites/simpletest
      
      The directory contents are gitignored and should be cleaned after test runs.
      Use the prepare-test-env.sh script to automate this setup.
    -->
  </php>
  
</phpunit>
